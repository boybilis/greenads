Options -MultiViews

RewriteEngine On
RewriteBase /

# Keep real files, folders, ajax endpoints, and page includes untouched.
RewriteCond %{REQUEST_URI} !^/ajax/ [NC]
RewriteCond %{REQUEST_URI} !^/pages/ [NC]

# Redirect direct .php page visits to clean URLs.
RewriteCond %{REQUEST_METHOD} =GET
RewriteCond %{THE_REQUEST} \s/+(.+?)\.php[?\s] [NC]
RewriteRule ^ %1 [R=302,L]

# Serve clean URLs from matching PHP files.
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+?)/?$ $1.php [L,QSA]
